    "A wallet-specific Nostr key has been generated for you. You can replace it with your own key below if desired." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم إنشاء مفتاح Nostr خاص بالمحفظة لك. يمكنك استبداله بمفتاحك الخاص أدناه إذا رغبت."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার জন্য একটি Wallet-নির্দিষ্ট Nostr Key তৈরি করা হয়েছে। আপনি চাইলে নিচে আপনার নিজের Key দিয়ে প্রতিস্থাপন করতে পারেন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Wallet-spezifischer Nostr-Key wurde für dich generiert. Du kannst ihn mit deinem eigenen ersetzen falls gewünscht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ha generado una clave Nostr específica para tu wallet. Puedes reemplazarla con tu propia clave a continuación si lo deseas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une clé Nostr spécifique au wallet a été générée pour toi. Tu peux la remplacer par ta propre clé ci-dessous si tu le souhaites."
          }
