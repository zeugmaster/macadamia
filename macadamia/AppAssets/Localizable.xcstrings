    "Payment amount approaching the total balance risks payment failure due to fees." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اقتراب مبلغ الدفع من الرصيد الإجمالي يخاطر بفشل الدفع بسبب الرسوم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পেমেন্টের পরিমাণ মোট ব্যালেন্সের কাছাকাছি হলে ফি-এর কারণে পেমেন্ট ব্যর্থ হতে পারে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beträge nahe des Gesamt-Guthabens riskieren Fehler aufgrund von Gebühren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monto del pago cercano al saldo total arriesga un fallo por tarifas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un montant de paiement proche du solde total risque un échec dû aux frais."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुल शेष के करीब भुगतान राशि शुल्क के कारण विफलता का जोखिम रखती है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "支払額が合計残高に近づくと、手数料により支払いが失敗する可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "결제 금액이 총 잔액에 가까우면 수수료로 인해 결제가 실패할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O valor do pagamento próximo ao saldo total arrisca falha por taxas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сумма платежа, близкая к общему балансу, рискует неудачей из-за комиссий."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ödeme tutarı toplam bakiyeye yaklaşırsa ücretler nedeniyle ödeme başarısız olabilir."
          }
        }
      }
    },
