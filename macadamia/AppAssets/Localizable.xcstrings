    "Please enter a valid URL. If no protocol is specified, https:// will be used." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى إدخال عنوان URL صالح. إذا لم يتم تحديد بروتوكول، سيتم استخدام https://."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "একটি বৈধ URL লিখুন। প্রোটোকল নির্দিষ্ট না থাকলে https:// ব্যবহার করা হবে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte gib eine gültige URL ein. Wenn kein Protokoll genannt ist, wird HTTPS:// angenommen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingresa una URL válida. Si no se especifica protocolo, se usará https://."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entre une URL valide. Si aucun protocole n'est spécifié, https:// sera utilisé."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कृपया एक वैध URL दर्ज करें। यदि कोई प्रोटोकॉल निर्दिष्ट नहीं है, तो https:// का उपयोग किया जाएगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効なURLを入力してください。プロトコルが指定されていない場合、https://が使用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "유효한 URL을 입력하세요. 프로토콜이 지정되지 않으면 https://가 사용됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Digite uma URL válida. Se nenhum protocolo for especificado, https:// será usado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
