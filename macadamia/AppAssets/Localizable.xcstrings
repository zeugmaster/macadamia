          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ইন্টার-মিন্ট ট্রান্সফার আপনাকে Lightning Network-এর মাধ্যমে একটি বিশ্বস্ত Mint থেকে অন্যটিতে ecash স্থানান্তর করতে দেয়।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Transfer ermöglicht dir Ecash von einer bekannten Mint zu einer anderen durch das Lightning Netzwerk zu übertragen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una transferencia entre mints te permite mover ecash de un mint de confianza a otro a través de la red Lightning."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un transfert inter-mint te permet de déplacer de l'ecash d'un mint de confiance à un autre via le réseau Lightning."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इंटर-मिंट ट्रांसफर आपको Lightning Network के माध्यम से एक विश्वसनीय Mint से दूसरे में ecash स्थानांतरित करने की अनुमति देता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ミント間転送により、Lightning Networkを介して信頼するミントから別のミントにecashを移動できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "민트 간 전송을 통해 Lightning Network를 사용하여 신뢰하는 민트에서 다른 민트로 ecash를 이동할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma transferência entre mints permite mover ecash de um mint confiável para outro via rede Lightning."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перевод между минтами позволяет переместить ecash с одного доверенного минта на другой через сеть Lightning."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mint'ler arası transfer, Lightning Network üzerinden ecash'i güvendiğin bir Mint'ten diğerine taşımanı sağlar."
          }
        }
      }
    },
