        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके लिए एक Wallet-विशिष्ट Nostr Key बनाई गई है। आप चाहें तो इसे नीचे अपनी Key से बदल सकते हैं।"
