    "Transfer amount approaching the total balance risks payment failure due to fees." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اقتراب مبلغ التحويل من الرصيد الإجمالي يخاطر بفشل الدفع بسبب الرسوم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ট্রান্সফারের পরিমাণ মোট ব্যালেন্সের কাছাকাছি হলে ফি-এর কারণে ব্যর্থ হতে পারে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beträge nahe des Gesamt-Guthabens riskieren Fehler aufgrund von Gebühren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monto de transferencia cercano al saldo total arriesga un fallo por tarifas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un montant de transfert proche du solde total risque un échec dû aux frais."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुल शेष के करीब ट्रांसफर राशि शुल्क के कारण विफलता का जोखिम रखती है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "転送額が合計残高に近づくと、手数料により失敗する可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "전송 금액이 총 잔액에 가까우면 수수료로 인해 실패할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O valor da transferência próximo ao saldo total arrisca falha por taxas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сумма перевода, близкая к общему балансу, рискует неудачей из-за комиссий."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transfer tutarı toplam bakiyeye yaklaşırsa ücretler nedeniyle başarısız olabilir."
          }
        }
      }
    },
