    "Camera access has been denied. Please enable it in the Settings app to scan QR codes." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم رفض الوصول إلى الكاميرا. يرجى تفعيله في الإعدادات لمسح رموز QR."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ক্যামেরা অ্যাক্সেস অস্বীকার করা হয়েছে। QR কোড স্ক্যান করতে সেটিংস অ্যাপে সক্রিয় করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamera-Zugriff wurde verweigert. Bitte erteile Zugriff in den Einstellungen um QR-Codes zu scannen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ha denegado el acceso a la cámara. Actívalo en Ajustes para escanear códigos QR."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la caméra a été refusé. Active-le dans les Réglages pour scanner les QR codes."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कैमरा एक्सेस अस्वीकार कर दिया गया है। QR कोड स्कैन करने के लिए सेटिंग्स ऐप में सक्षम करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラへのアクセスが拒否されました。QRコードをスキャンするには設定アプリで有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라 접근이 거부되었습니다. QR 코드를 스캔하려면 설정 앱에서 활성화하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à câmera foi negado. Ative nas Configurações para escanear QR codes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к камере запрещён. Включи его в Настройках, чтобы сканировать QR-коды."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamera erişimi reddedildi. QR kodları taramak için Ayarlar'dan etkinleştir."
          }
        }
      }
    },
    "Camera access is restricted. This might be due to parental controls or other restrictions." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوصول إلى الكاميرا مقيّد. قد يكون ذلك بسبب الرقابة الأبوية أو قيود أخرى."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ক্যামেরা অ্যাক্সেস সীমাবদ্ধ। এটি প্যারেন্টাল কন্ট্রোল বা অন্যান্য সীমাবদ্ধতার কারণে হতে পারে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamera-Zugriff ist eingeschränkt. Dies kann an Eltern-Freigabe oder anderen Einschränkungen liegen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la cámara está restringido. Esto puede deberse a controles parentales u otras restricciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès à la caméra est restreint. Cela peut être dû au contrôle parental ou à d'autres restrictions."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कैमरा एक्सेस प्रतिबंधित है। यह पैरेंटल कंट्रोल या अन्य प्रतिबंधों के कारण हो सकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カメラへのアクセスが制限されています。ペアレンタルコントロールなどの制限が原因の可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "카메라 접근이 제한되어 있습니다. 자녀 보호 기능이나 기타 제한 때문일 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O acesso à câmera está restrito. Isso pode ser devido ao controle dos pais ou outras restrições."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к камере ограничен. Это может быть из-за родительского контроля или других ограничений."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamera erişimi kısıtlanmış. Bu ebeveyn denetimleri veya başka kısıtlamalardan kaynaklanıyor olabilir."
          }
        }
      }
    },
