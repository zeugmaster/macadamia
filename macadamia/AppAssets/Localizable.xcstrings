    "Hold and drag to change the order. The first mint will be the default selected across the application." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط مع الاستمرار واسحب لتغيير الترتيب. أول mint سيكون المحدد افتراضيًا في التطبيق."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ক্রম পরিবর্তন করতে ধরে টানুন। প্রথম Mint অ্যাপ জুড়ে ডিফল্ট হিসেবে নির্বাচিত হবে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten und bewegen um die Reihenfolge zu ändern. Die erste Mint wird als Standard in der App verwendet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén presionado y arrastra para cambiar el orden. El primer mint será el seleccionado por defecto en toda la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintiens et glisse pour changer l'ordre. Le premier mint sera celui sélectionné par défaut dans l'application."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्रम बदलने के लिए दबाकर रखें और खींचें। पहला Mint ऐप में डिफ़ॉल्ट रूप से चयनित होगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長押ししてドラッグで順序を変更できます。最初のミントがアプリ全体でデフォルトとして選択されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "길게 누르고 드래그하여 순서를 변경하세요. 첫 번째 민트가 앱 전체에서 기본 선택됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segure e arraste para alterar a ordem. O primeiro mint será o selecionado por padrão no aplicativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удерживай и перетаскивай для изменения порядка. Первый минт будет выбран по умолчанию во всём приложении."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sırayı değiştirmek için basılı tut ve sürükle. İlk Mint, uygulama genelinde varsayılan olarak seçilecektir."
          }
        }
      }
