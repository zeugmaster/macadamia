    "On-chain Bitcoin payments are not supported" : {

    },
    "One or both mints for this transfer could not be found." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذر العثور على أحد أو كلا المنتين لهذا التحويل."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই ট্রান্সফারের জন্য এক বা উভয় Mint পাওয়া যায়নি।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einer oder beide Mints für diesen Transfer konnten nicht gefunden werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo encontrar uno o ambos mints para esta transferencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ou les deux mints pour ce transfert sont introuvables."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस ट्रांसफर के लिए एक या दोनों Mint नहीं मिले।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この転送のミントが見つかりませんでした。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 전송에 필요한 민트 중 하나 또는 두 개 모두를 찾을 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um ou ambos os mints para esta transferência não foram encontrados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Один или оба минта для этого перевода не найдены."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu transfer için Mint'lerden biri veya ikisi de bulunamadı."
          }
        }
      }
    },
    "One or more parts of this payment are still pending. Please check again later to make sure the lightning payment was successful." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جزء واحد أو أكثر من هذا الدفع لا يزال معلقًا. يرجى التحقق لاحقًا للتأكد من نجاح دفع Lightning."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই পেমেন্টের এক বা একাধিক অংশ এখনো অমীমাংসিত। Lightning পেমেন্ট সফল হয়েছে কিনা পরে আবার পরীক্ষা করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mindestens ein Teil dieser Zahlung ist noch ausstehend. Bitte probiere es später noch einmal um sicherzustellen, dass die Lightning-Zahlung erfolgreich war."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una o más partes de este pago aún están pendientes. Vuelve a verificar más tarde para asegurar que el pago Lightning fue exitoso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une ou plusieurs parties de ce paiement sont encore en attente. Vérifie à nouveau plus tard pour t'assurer que le paiement Lightning a réussi."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस भुगतान के एक या अधिक हिस्से अभी भी लंबित हैं। कृपया बाद में फिर से जांचें कि Lightning भुगतान सफल रहा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この支払いの一部がまだ保留中です。Lightning支払いが成功したか後で再確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 결제의 일부가 아직 대기 중입니다. 나중에 다시 확인하여 라이트닝 결제가 성공했는지 확인하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma ou mais partes deste pagamento ainda estão pendentes. Verifique novamente mais tarde para garantir que o pagamento Lightning foi bem-sucedido."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одна или несколько частей этого платежа всё ещё ожидают. Проверь позже, чтобы убедиться, что Lightning-платёж прошёл успешно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu ödemenin bir veya daha fazla kısmı hâlâ beklemede. Lightning ödemesinin başarılı olduğundan emin olmak için daha sonra tekrar kontrol et."
          }
        }
      }
    },
    "One or more transfers would exceed safe limits. Please adjust your allocation to leave more balance for fees." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحويل واحد أو أكثر سيتجاوز الحدود الآمنة. يرجى تعديل تخصيصك لترك رصيد أكبر للرسوم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এক বা একাধিক ট্রান্সফার নিরাপদ সীমা অতিক্রম করবে। ফি-এর জন্য আরো ব্যালেন্স রাখতে আপনার বরাদ্দ সমন্বয় করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mindestens ein Teil der Zahlung würde das anteilige Guthaben übersteigen. Bitte passe die Aufteilung an um mehr Platz für Gebühren zu lassen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una o más transferencias excederían los límites seguros. Ajusta tu asignación para dejar más saldo para tarifas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ou plusieurs transferts dépasseraient les limites sûres. Ajuste ton allocation pour laisser plus de solde pour les frais."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक या अधिक ट्रांसफर सुरक्षित सीमा से अधिक हो जाएंगे। शुल्क के लिए अधिक शेष छोड़ने हेतु अपना आवंटन समायोजित करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1つ以上の転送が安全な制限を超えます。手数料のために残高を多く残すよう割り当てを調整してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하나 이상의 전송이 안전 한도를 초과합니다. 수수료를 위해 더 많은 잔액을 남기도록 할당을 조정하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma ou mais transferências excederiam limites seguros. Ajuste sua alocação para deixar mais saldo para taxas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Один или несколько переводов превысят безопасные лимиты. Скорректируй распределение, чтобы оставить больше баланса для комиссий."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir veya daha fazla transfer güvenli limitleri aşacak. Ücretler için daha fazla bakiye bırakmak üzere dağılımını ayarla."
          }
        }
      }
    },
