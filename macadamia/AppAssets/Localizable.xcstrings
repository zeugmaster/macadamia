    "The entered text does not appear to be a properly formmatted seed phrase. Make sure its twelve words, separated by spaces or line breaks." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يبدو أن النص المُدخل عبارة بذرة منسقة بشكل صحيح. تأكد من أنها اثنتا عشرة كلمة مفصولة بمسافات أو فواصل أسطر."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রবিষ্ট টেক্সট সঠিকভাবে ফরম্যাটেড সিড ফ্রেজ মনে হচ্ছে না। নিশ্চিত করুন যে এটি বারোটি শব্দ, স্পেস বা লাইন ব্রেক দিয়ে আলাদা।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der eingegebene Text scheint keine korrekt formatierte Seed-Phrase zu sein. Stelle sicher, dass es zwölf Wörter sind, getrennt durch Leerzeichen oder Zeilenumbrüche."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El texto ingresado no parece ser una frase semilla con formato correcto. Asegúrate de que sean doce palabras separadas por espacios o saltos de línea."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le texte saisi ne semble pas être une phrase de récupération correctement formatée. Assure-toi que ce sont douze mots séparés par des espaces ou des sauts de ligne."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "दर्ज किया गया टेक्स्ट सही प्रारूप में सीड फ्रेज़ नहीं लगता। सुनिश्चित करें कि यह बारह शब्द हैं, स्पेस या लाइन ब्रेक से अलग।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "入力されたテキストは正しい形式のシードフレーズではないようです。スペースまたは改行で区切られた12単語であることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "입력한 텍스트가 올바른 형식의 시드 구문이 아닌 것 같습니다. 공백이나 줄바꿈으로 구분된 12개의 단어인지 확인하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O texto inserido não parece ser uma frase semente formatada corretamente. Certifique-se de que são doze palavras separadas por espaços ou quebras de linha."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Введённый текст не похож на правильно отформатированную сид-фразу. Убедись, что это двенадцать слов, разделённых пробелами или переносами строк."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Girilen metin düzgün biçimlendirilmiş bir seed ifadesi gibi görünmüyor. On iki kelime olduğundan ve boşluk veya satır sonlarıyla ayrıldığından emin ol."
          }
        }
      }
    },
    "The mint could not be reached due to a network issue. Are you both online?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذر الوصول إلى الـ mint بسبب مشكلة في الشبكة. هل أنتما متصلان؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নেটওয়ার্ক সমস্যার কারণে Mint-এ পৌঁছানো যায়নি। আপনারা দুজনই কি অনলাইনে আছেন?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Mint konnte nicht wegen eines Netzwerkfehlers nicht erreicht werden. Seid ihr beide online?"
