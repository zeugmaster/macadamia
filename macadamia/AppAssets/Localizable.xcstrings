    "The provided string %@ does not seem to be valid. Please send the ecash manually or reclaim it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "النص المقدم %@ لا يبدو صالحًا. يرجى إرسال الـ ecash يدويًا أو استرداده."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রদত্ত স্ট্রিং %@ বৈধ মনে হচ্ছে না। দয়া করে ecash ম্যানুয়ালি পাঠান বা পুনরুদ্ধার করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der angegebene Text %@ scheint nicht gültig zu sein. Bitte sende das Ecash manuell oder löse es wieder ein."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El texto proporcionado %@ no parece ser válido. Envía el ecash manualmente o recupéralo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La chaîne fournie %@ ne semble pas valide. Envoie l'ecash manuellement ou récupère-le."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रदान की गई स्ट्रिंग %@ वैध नहीं लगती। कृपया ecash मैन्युअल रूप से भेजें या पुनः प्राप्त करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "提供された文字列%@は有効ではないようです。ecashを手動で送信するか、回収してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "제공된 문자열 %@이(가) 유효하지 않은 것 같습니다. ecash를 수동으로 보내거나 회수하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A string fornecida %@ não parece ser válida. Envie o ecash manualmente ou recupere-o."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
