    "This blinded message has already been signed, indicating an issue during deterministic secret generation." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الرسالة المعمّاة موقعة بالفعل، مما يشير إلى مشكلة أثناء إنشاء الأسرار الحتمي."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই ব্লাইন্ডেড মেসেজ ইতিমধ্যে সাইন করা হয়েছে, যা ডিটারমিনিস্টিক সিক্রেট জেনারেশনে সমস্যা নির্দেশ করে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Blindnachricht wurde bereits signiert, was auf ein Problem bei der deterministischen Erzeugung der “Secrets” hindeutet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este mensaje ciego ya fue firmado, lo que indica un problema durante la generación determinística de secretos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce message aveugle a déjà été signé, indiquant un problème lors de la génération déterministe des secrets."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह ब्लाइंडेड संदेश पहले से हस्ताक्षरित है, जो डिटर्मिनिस्टिक सीक्रेट जनरेशन के दौरान समस्या दर्शाता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このブラインドメッセージはすでに署名されており、決定論的シークレット生成中の問題を示しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 블라인드 메시지는 이미 서명되었으며, 결정적 비밀 생성 중 문제가 있음을 나타냅니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta mensagem cega já foi assinada, indicando um problema durante a geração determinística de segredos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это слепое сообщение уже подписано, что указывает на проблему при детерминированной генерации секретов."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu kör mesaj zaten imzalanmış, bu da deterministik gizli anahtar üretiminde bir sorun olduğunu gösteriyor."
          }
        }
      }
    },
    "This field supports BOLT11 invoices, LNURL strings (LNURL1...) or Lightning Addresses (e.g. user@host.com)." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يدعم هذا الحقل فواتير BOLT11 أو سلاسل LNURL (LNURL1...) أو عناوين Lightning (مثل user@host.com)."
          }
        },
        "bn" : {
          "stringUnit" : {
